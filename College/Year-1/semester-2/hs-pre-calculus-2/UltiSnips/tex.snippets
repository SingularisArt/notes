snippet les "Lesson"
\lesson{${1:NUM}}{`date "+%b %d %Y %a (%H:%M:%S)"`}{${2:NAME}}
\label{les_$1:${3:${2/\\\w+\{(.*?)\}|\\(.)|(\w+)|([^\w\\]+)/(?4:_:\L$1$2$3\E)/ga}}}

$0

\newpage
endsnippet


########
# TRIG #
########

context "math()"
snippet dtan "Definition of Tangent" Ai
\tan = \left(${1:\theta}\right) = \frac{\sin \left($1\right)}{\cos \left($1\right)}
endsnippet

context "math()"
snippet dcot "Definition of Cotangent" Ai
\cot \left(${1:\theta}\right) = \frac{1}{tan \left($1\right)}
endsnippet

context "math()"
snippet dsec "Definition of Secant" Ai
\sec \left(${1:\theta}\right) = \frac{1}{cos \left($1\right)}
endsnippet

context "math()"
snippet dcsc "Definition of Cosecant" Ai
\csc \left(${1:\theta}\right) = \frac{1}{sin \left($1\right)}
endsnippet
